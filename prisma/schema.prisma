// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// SQLite doesn't support enums, using String with constraints instead

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  name      String?
  nickname  String?
  phone     String?
  wechatId  String?
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 投资人创建的分身
  avatars Avatar[]

  // 人选发起的聊天
  chatsAsCandidate Chat[] @relation("CandidateChats")

  // 投资人外部账户集成
  integrations InvestorIntegration[]

  // 投资人维护的公众号源
  wechatSources InvestorWechatSource[]

  // 投资人 AI 员工会话
  agentThreads AgentThread[]

  @@map("users")
}

model AgentThread {
  id        String   @id @default(cuid())
  agentType String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  messages  AgentMessage[]
  toolCalls AgentToolCall[]

  @@index([investorId, agentType, updatedAt])
  @@map("agent_threads")
}

model AgentMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  meta      Json?
  createdAt DateTime @default(now())

  threadId String
  thread   AgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  toolCalls AgentToolCall[]

  @@index([threadId, createdAt])
  @@map("agent_messages")
}

model AgentToolCall {
  id         String   @id @default(cuid())
  toolName   String
  status     String   @default("SUCCESS")
  toolArgs   Json?
  toolResult Json?
  createdAt  DateTime @default(now())

  threadId String
  thread   AgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  messageId String?
  message   AgentMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([threadId, createdAt])
  @@index([messageId])
  @@map("agent_tool_calls")
}

model InvestorWechatSource {
  id             String   @id @default(cuid())
  biz            String
  displayName    String
  description    String?
  lastArticleUrl String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([investorId, biz])
  @@index([investorId, updatedAt])
  @@map("investor_wechat_sources")
}

model InvestorIntegration {
  id           String   @id @default(cuid())
  provider     String
  status       String   @default("CONNECTED")
  accountEmail String?
  accountName  String?
  assistantCustomPrompt String?
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  investorId String
  investor   User @relation(fields: [investorId], references: [id], onDelete: Cascade)

  snapshots IntegrationSnapshot[]

  @@unique([investorId, provider])
  @@index([provider, updatedAt])
  @@map("investor_integrations")
}

model IntegrationSnapshot {
  id           String   @id @default(cuid())
  provider     String
  summary      String
  raw          Json?
  createdAt    DateTime @default(now())

  integrationId String
  integration   InvestorIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, createdAt])
  @@map("integration_snapshots")
}

model Avatar {
  id          String       @id @default(cuid())
  name        String
  description String?
  avatar      String?      // 头像URL
  systemPrompt String     // AI 系统提示词
  status      String @default("ACTIVE")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // 所属投资人
  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  // 与此分身的聊天
  chats Chat[]

  @@map("avatars")
}

model Chat {
  id        String     @id @default(cuid())
  title     String?
  status    String @default("ACTIVE")
  summary   String?    // AI 生成的聊天总结
  qualificationStatus String @default("PENDING") // PENDING | NEEDS_INFO | QUALIFIED | REJECTED
  qualificationScore Int @default(0) // 0-100
  qualificationReason String?
  needsInvestorReview Boolean @default(false)
  lastEvaluatedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // 人选
  candidateId String
  candidate   User   @relation("CandidateChats", fields: [candidateId], references: [id], onDelete: Cascade)

  // 对应的分身
  avatarId String
  avatar   Avatar @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  // 聊天消息
  messages Message[]

  @@index([candidateId, avatarId, status])
  @@index([avatarId, qualificationStatus, needsInvestorReview])
  @@map("chats")
}

model Message {
  id        String   @id @default(cuid())
  content   String
  role      String   // "user" 或 "assistant"
  createdAt DateTime @default(now())

  // 所属聊天
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@map("messages")
}
