// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// SQLite doesn't support enums, using String with constraints instead

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  name      String?
  nickname  String?
  phone     String?
  wechatId  String?
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // comment
  avatars Avatar[]

  // comment
  chatsAsCandidate Chat[] @relation("CandidateChats")

  // comment
  integrations InvestorIntegration[]

  // comment
  wechatSources InvestorWechatSource[]

  // comment AI teammatecomment
  agentThreads AgentThread[]

  // commentHirecomment
  teamHires InvestorTeamHire[]

  // comment AI teammatecomment
  agentConfigs InvestorAgentConfig[]

  // Executive Assistantcomment
  executiveBriefings ExecutiveBriefing[]

  // Executive Assistantcomment
  executiveAssistantRuns ExecutiveAssistantRun[]

  creditAccount      CreditAccount?
  creditSubscription CreditSubscription?
  creditReservations CreditReservation[]
  creditLedger       CreditLedgerEntry[]
  agentUsageRecords  AgentUsageRecord[]

  @@index([email], map: "users_email_idx")
  @@map("users")
}

model CreditAccount {
  id                      String   @id @default(cuid())
  balanceCredits          Int      @default(0)
  reservedCredits         Int      @default(0)
  lifetimeGrantedCredits  Int      @default(0)
  lifetimeSpentCredits    Int      @default(0)
  lifetimeRefundedCredits Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  investorId String @unique
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  reservations CreditReservation[]
  ledger       CreditLedgerEntry[]
  usageRecords AgentUsageRecord[]

  @@map("credit_accounts")
}

model CreditSubscription {
  id                     String    @id @default(cuid())
  planKey                String    @default("FREE")
  status                 String    @default("ACTIVE")
  monthlyCredits         Int       @default(0)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  provider               String?
  providerCustomerId     String?
  providerSubscriptionId String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  investorId String @unique
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([status, currentPeriodEnd])
  @@map("credit_subscriptions")
}

model CreditReservation {
  id               String    @id @default(cuid())
  runId            String    @unique
  status           String    @default("ACTIVE")
  mode             String    @default("OBSERVE")
  hermesModel      String?
  estimatedCredits Int
  reservedCredits  Int       @default(0)
  capturedCredits  Int       @default(0)
  shortfallCredits Int       @default(0)
  expiresAt        DateTime
  settledAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  accountId String
  account   CreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  threadId String?
  ledger   CreditLedgerEntry[]

  @@index([accountId, status, expiresAt])
  @@index([investorId, createdAt])
  @@index([threadId, createdAt])
  @@map("credit_reservations")
}

model CreditLedgerEntry {
  id                   String   @id @default(cuid())
  type                 String
  amountCredits        Int      @default(0)
  reservedDeltaCredits Int      @default(0)
  balanceAfterCredits  Int
  reservedAfterCredits Int
  description          String
  idempotencyKey       String   @unique
  runId                String?
  threadId             String?
  metadata             Json?
  createdAt            DateTime @default(now())

  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  accountId String
  account   CreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  reservationId String?
  reservation   CreditReservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([investorId, createdAt])
  @@index([runId])
  @@map("credit_ledger_entries")
}

model AgentUsageRecord {
  id              String   @id @default(cuid())
  runId           String   @unique
  status          String   @default("RECORDED")
  hermesModel     String?
  codexModel      String?
  hermesCostUsd   Decimal  @default(0) @db.Decimal(16, 8)
  hermesCredits   Int      @default(0)
  codexCredits    Int      @default(0)
  computedCredits Int      @default(0)
  billedCredits   Int      @default(0)
  usage           Json
  pricingVersion  String   @default("2026-07-v1")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  accountId String
  account   CreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  threadId String?

  @@index([accountId, createdAt])
  @@index([investorId, createdAt])
  @@index([threadId, createdAt])
  @@map("agent_usage_records")
}

model ExecutiveAssistantRun {
  id           String    @id @default(cuid())
  status       String    @default("QUEUED")
  request      Json
  result       Json?
  error        String?
  planner      Json?
  plannerTrace Json?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([investorId, createdAt])
  @@index([status, updatedAt])
  @@map("executive_assistant_runs")
}

model ExecutiveBriefing {
  id        String   @id @default(cuid())
  dateKey   String
  title     String
  summary   String
  sections  Json
  sources   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([investorId, dateKey])
  @@index([investorId, updatedAt])
  @@map("executive_briefings")
}

model InvestorAgentConfig {
  id           String   @id @default(cuid())
  agentType    String
  systemPrompt String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([investorId, agentType])
  @@index([agentType, updatedAt])
  @@map("investor_agent_configs")
}

model AgentThread {
  id        String   @id @default(cuid())
  agentType String
  title     String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  messages  AgentMessage[]
  toolCalls AgentToolCall[]

  @@index([investorId, agentType, status, updatedAt])
  @@map("agent_threads")
}

model AgentMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  meta      Json?
  createdAt DateTime @default(now())

  threadId String
  thread   AgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  toolCalls AgentToolCall[]

  @@index([threadId, createdAt])
  @@map("agent_messages")
}

model AgentToolCall {
  id         String   @id @default(cuid())
  toolName   String
  status     String   @default("SUCCESS")
  toolArgs   Json?
  toolResult Json?
  createdAt  DateTime @default(now())

  threadId String
  thread   AgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  messageId String?
  message   AgentMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([threadId, createdAt])
  @@index([messageId])
  @@map("agent_tool_calls")
}

model InvestorWechatSource {
  id                  String    @id @default(cuid())
  biz                 String
  displayName         String
  description         String?
  lastArticleUrl      String
  profile             Json?
  profileUpdatedAt    DateTime?
  profileConfidence   Float?
  lastProfileEvidence Json?
  lastScannedAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([investorId, biz])
  @@index([investorId, updatedAt])
  @@map("investor_wechat_sources")
}

model InvestorIntegration {
  id                    String    @id @default(cuid())
  provider              String
  status                String    @default("CONNECTED")
  accountEmail          String?
  accountName           String?
  assistantCustomPrompt String?
  accessToken           String?
  refreshToken          String?
  expiresAt             DateTime?
  scope                 String?
  connectedAt           DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  snapshots IntegrationSnapshot[]

  @@unique([investorId, provider])
  @@index([provider, updatedAt])
  @@map("investor_integrations")
}

model InvestorTeamHire {
  id        String   @id @default(cuid())
  teamKey   String
  status    String   @default("HIRED")
  agentName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([investorId, teamKey])
  @@index([investorId, status, updatedAt])
  @@map("investor_team_hires")
}

model IntegrationSnapshot {
  id        String   @id @default(cuid())
  provider  String
  summary   String
  raw       Json?
  createdAt DateTime @default(now())

  integrationId String
  integration   InvestorIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, createdAt])
  @@map("integration_snapshots")
}

model Avatar {
  id           String   @id @default(cuid())
  name         String
  description  String?
  avatar       String? // commentURL
  systemPrompt String // AI comment
  status       String   @default("ACTIVE")
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // comment
  investorId String
  investor   User   @relation(fields: [investorId], references: [id], onDelete: Cascade)

  // comment
  chats Chat[]

  @@map("avatars")
}

model Chat {
  id                  String    @id @default(cuid())
  title               String?
  status              String    @default("ACTIVE")
  summary             String? // AI comment
  qualificationStatus String    @default("PENDING") // PENDING | NEEDS_INFO | QUALIFIED | REJECTED
  qualificationScore  Int       @default(0) // 0-100
  qualificationReason String?
  needsInvestorReview Boolean   @default(false)
  lastEvaluatedAt     DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // comment
  candidateId String
  candidate   User   @relation("CandidateChats", fields: [candidateId], references: [id], onDelete: Cascade)

  // comment
  avatarId String
  avatar   Avatar @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  // comment
  messages Message[]

  @@index([candidateId, avatarId, status])
  @@index([avatarId, qualificationStatus, needsInvestorReview])
  @@map("chats")
}

model Message {
  id        String   @id @default(cuid())
  content   String
  role      String // "user" comment "assistant"
  createdAt DateTime @default(now())

  // comment
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@map("messages")
}
