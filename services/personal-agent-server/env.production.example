PORT=8787
ALTSELFS_AGENT_ENV=production
AGENT_PROCESS_ROLE=all
AGENT_DIRECT_TURN_EXECUTION_ENABLED=false

# Storage
STORAGE_BACKEND=postgres
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
AGENT_CONTEXT_DATABASE_URL=postgres://RDS_USER:RDS_PASSWORD@RDS_HOST:5432/AGENT_DB

# Credits ledger. This must point to the product Supabase Postgres database,
# never to AGENT_CONTEXT_DATABASE_URL.
BILLING_DATABASE_URL=postgres://SUPABASE_USER:SUPABASE_PASSWORD@SUPABASE_HOST:5432/postgres
CREDITS_ENFORCEMENT_MODE=observe
CREDITS_WELCOME_GRANT=1000
CREDITS_CONCURRENCY_HOLD=50
CREDITS_RESERVATION_TTL_MINUTES=120
CREDITS_PER_USD=1000
CREDITS_COST_MARKUP=2
CREDITS_MINIMUM_RUN_CHARGE=5
CODEX_USAGE_UNCACHED_INPUT_RATE=125
CODEX_USAGE_CACHED_INPUT_RATE=12.5
CODEX_USAGE_OUTPUT_RATE=750
CODEX_USAGE_CREDIT_MULTIPLIER=7.5

# The product plan is enforced when the task is authorized. This worker value
# is only a deployment capacity ceiling and should accommodate the largest plan.
AGENT_TURN_MAX_PER_USER=20
AGENT_TURN_MAX_PER_THREAD=1
AGENT_TURN_CANCEL_POLL_MS=1500

# Per-user runtime data. Mount /data/altselfs-agent from the host.
CODEX_HOME_ROOT=/data/altselfs-agent/codex-homes
WORKSPACE_ROOT=/data/altselfs-agent/workspaces
HERMES_HOME_ROOT=/data/altselfs-agent/hermes-homes
HERMES_WORKSPACE_ROOT=/data/altselfs-agent/hermes-workspaces
PROFILE_STORE_PATH=/data/altselfs-agent/profiles.json
MEMORY_REVIEW_JOB_STORE_PATH=/data/altselfs-agent/memory-review-jobs.json

# Product path currently used for cloud validation.
HERMES_SOURCE_RUNTIME_ENABLED=false
HERMES_ROUTER_ENABLED=true
MEMORY_REVIEW_MODE=async
RUNTIME_STATE_MODE=sandbox
SANDBOX_STORAGE_ROOT=/data/altselfs-agent

# Generalized command/Python sandbox for codex-general and codex-competitive-intelligence.
# This does not expose the host shell. The server creates short-lived Docker containers
# with /workspace bind-mounted to the current user's thread workspace.
SANDBOX_EXEC_ENABLED=false
SANDBOX_DOCKER_SOCKET_PATH=/var/run/docker.sock
SANDBOX_EXEC_IMAGE=crpi-pvisgh9yojd87fkj.cn-hangzhou.personal.cr.aliyuncs.com/altselfs/sandbox-exec-runtime:latest
SANDBOX_EXEC_MEMORY_BYTES=536870912
SANDBOX_EXEC_NANO_CPUS=1000000000
SANDBOX_EXEC_PIDS_LIMIT=128
SANDBOX_EXEC_TIMEOUT_MS=120000
SANDBOX_EXEC_MAX_OUTPUT_BYTES=262144
SANDBOX_EXEC_WORKSPACE_MAX_BYTES=536870912
SANDBOX_EXEC_TMPFS_SIZE_BYTES=67108864
SANDBOX_EXEC_NETWORK_ENABLED=false
SANDBOX_EXEC_PROXY_URL=http://172.18.0.1:7890

# Models. Hermes owns the outer loop; Codex remains the execution agent.
HERMES_MODEL=claude-sonnet-4-6
HERMES_PROVIDER=apiyi
HERMES_BASE_URL=https://api.apiyi.com/v1
HERMES_API_KEY_ENV=APIYI_API_KEY
APIYI_API_KEY=
CODEX_MODEL=gpt-5.5
CODEX_MODEL_PROVIDER=openai
CODEX_MODEL_CONTEXT_WINDOW=128000
CODEX_MODEL_AUTO_COMPACT_TOKEN_LIMIT=64000
CODEX_TOOL_OUTPUT_TOKEN_LIMIT=12000
CODEX_WEB_SEARCH_MODE=live
CODEX_GENERAL_DISABLE_LOCAL_ENVIRONMENT=true

# OpenAI Codex provider is used only when a turn selects an OpenAI model such as gpt-5.5.
# Keep this auth file outside git and mount/copy it onto the ECS host.
CODEX_OPENAI_AUTH_JSON_PATH=/data/altselfs-agent/secrets/codex-openai-auth.json
CODEX_OPENAI_PROXY_URL=http://172.18.0.1:7890

# Outbound proxy for external third-party APIs that need network egress through Mihomo/VPN.
# This is used only by code paths that explicitly opt in, not by database/internal traffic.
OUTBOUND_PROXY_URL=http://172.18.0.1:7890
OUTBOUND_PROXY_BYPASS_HOSTS=

# OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY_ENV=OPENROUTER_API_KEY
OPENROUTER_APP_TITLE=Altselfs Personal Agent Server
OPENROUTER_API_KEY=
OPENROUTER_FILE_PARSER_MODEL=qwen/qwen3.6-flash
OPENROUTER_IMAGE_PARSER_MODEL=qwen/qwen3.6-flash
OPENROUTER_FILE_PARSER_MAX_CHARS=60000
OPENROUTER_IMAGE_PARSER_MAX_TOKENS=4000
ARTIFACT_LOCAL_PARSER_TIMEOUT_MS=30000

# Web search provider, optional but expected for codex-general research tasks.
WEB_SEARCH_PROVIDER=auto
SERPAPI_API_KEY=
SERPER_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
WEB_SEARCH_TIMEOUT_MS=30000

# RapidAPI-backed competitive intelligence data sources. Users enable the Semrush
# employee in the app; the platform key below is used by codex-competitive-intelligence
# for similarweb-api1, semrush13, semrush8, and Domain Metrics Check.
RAPIDAPI_KEY=
RAPIDAPI_REQUEST_TIMEOUT_MS=30000

# User-authorized personal account credentials. MVP uses local envelope encryption:
# generate with `openssl rand -base64 32`, store the value in a root-only secret file
# on the ECS host, and mount /data/altselfs-agent into the container.
CREDENTIAL_VAULT_PROVIDER=local_envelope
CREDENTIAL_VAULT_MASTER_KEY_FILE=/data/altselfs-agent/secrets/credential-vault-master-key
CREDENTIAL_VAULT_KEY_VERSION=local-v1

# Gmail OAuth is initiated by the Next.js app and stored by personal-agent-server.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta / Instagram / Facebook tools use user tokens stored by the Next.js OAuth callback.
# The app id/secret live in the Next.js deployment; the backend only needs the Graph API version.
META_GRAPH_API_VERSION=v21.0

# Feishu/Lark enhanced connector. Normal binding uses a two-step lark-cli flow:
# (1) user creates/configures their own CLI app, (2) user authorizes their account.
# personal-agent-server stores encrypted lark-cli snapshots in RDS and only
# materializes them under this runtime directory during binding/tool calls.
LARK_CLI_BIN=lark-cli
LARK_CLI_HOME_ROOT=/data/altselfs-agent/lark-cli-runtime
LARK_CLI_TIMEOUT_MS=60000
# Leave empty by default. Feishu China endpoints usually work direct from ECS;
# set only if this deployment cannot reach accounts.feishu.cn/open.feishu.cn directly.
LARK_CLI_PROXY_URL=
# Optional legacy/global Feishu CLI app credentials and auth overrides. Normal
# binding does not require FEISHU_APP_ID/FEISHU_APP_SECRET.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Normal binding requests domains/scopes from user-selected feature packages.
FEISHU_CLI_AUTH_DOMAINS=
FEISHU_CLI_AUTH_EXTRA_SCOPES=
FEISHU_CLI_AUTH_EXCLUDE_SCOPES=

# Internal operations snapshot. Set the same token in the Next.js app as OPS_AGENT_TOKEN.
OPS_AGENT_TOKEN=

# Next.js ops dashboard cloud collectors are configured in the frontend/Vercel
# environment, not in this ECS service env:
# SUPABASE_ACCESS_TOKEN, SUPABASE_PROJECT_REF, SUPABASE_DB_LIMIT_BYTES, SUPABASE_STORAGE_LIMIT_BYTES
# VERCEL_ACCESS_TOKEN, VERCEL_PROJECT_ID, VERCEL_TEAM_ID
# ALIYUN_ACCESS_KEY_ID, ALIYUN_ACCESS_KEY_SECRET, ALIYUN_REGION_ID,
# ALIYUN_ECS_INSTANCE_ID or ALIYUN_ECS_DISK_IDS, ALIYUN_RDS_INSTANCE_ID
# SUPABASE_PROJECT_REF=ehizdgntykwlrirqgzeh
# SUPABASE_DB_LIMIT_BYTES=524288000
# SUPABASE_STORAGE_LIMIT_BYTES=1073741824
# ALIYUN_REGION_ID=cn-hangzhou
# ALIYUN_ECS_INSTANCE_ID=i-bp1dt8qff1jbkjsezzm4
# ALIYUN_RDS_INSTANCE_ID=pgm-bp131hj5rnkdn39x
# VERCEL_PROJECT_NAME=altselfs
# VERCEL_PROJECT_ID=prj_YIy2as4BnAEqy3YrstW1rZPkrZb1
# VERCEL_TEAM_ID=team_F093LUiKgS5Dgbt0cwtikjA4
