PORT=8787
ALTSELFS_AGENT_ENV=production
AGENT_PROCESS_ROLE=all

# Storage
STORAGE_BACKEND=postgres
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Per-user runtime data. Mount /data/altselfs-agent from the host.
CODEX_HOME_ROOT=/data/altselfs-agent/codex-homes
WORKSPACE_ROOT=/data/altselfs-agent/workspaces
HERMES_HOME_ROOT=/data/altselfs-agent/hermes-homes
HERMES_WORKSPACE_ROOT=/data/altselfs-agent/hermes-workspaces
PROFILE_STORE_PATH=/data/altselfs-agent/profiles.json
MEMORY_REVIEW_JOB_STORE_PATH=/data/altselfs-agent/memory-review-jobs.json

# Product path currently used for cloud validation.
HERMES_SOURCE_RUNTIME_ENABLED=false
HERMES_ROUTER_ENABLED=true
MEMORY_REVIEW_MODE=async

# Models
HERMES_MODEL=deepseek/deepseek-v3.2
CODEX_MODEL=deepseek/deepseek-v3.2
CODEX_MODEL_PROVIDER=openrouter
CODEX_MODEL_CONTEXT_WINDOW=128000
CODEX_MODEL_AUTO_COMPACT_TOKEN_LIMIT=64000
CODEX_TOOL_OUTPUT_TOKEN_LIMIT=12000
CODEX_WEB_SEARCH_MODE=live
CODEX_GENERAL_DISABLE_LOCAL_ENVIRONMENT=true

# OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY_ENV=OPENROUTER_API_KEY
OPENROUTER_APP_TITLE=Altselfs Personal Agent Server
OPENROUTER_API_KEY=
OPENROUTER_FILE_PARSER_MODEL=qwen/qwen3.6-flash
OPENROUTER_IMAGE_PARSER_MODEL=qwen/qwen3.6-flash
OPENROUTER_FILE_PARSER_MAX_CHARS=60000
OPENROUTER_IMAGE_PARSER_MAX_TOKENS=4000
ARTIFACT_LOCAL_PARSER_TIMEOUT_MS=30000

# Web search provider, optional but expected for codex-general research tasks.
WEB_SEARCH_PROVIDER=auto
SERPAPI_API_KEY=
SERPER_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
WEB_SEARCH_TIMEOUT_MS=30000

# RapidAPI-backed competitive intelligence data sources. Users enable the Semrush
# employee in the app; the platform key below is used by codex-competitive-intelligence
# for similarweb-api1, semrush13, semrush8, and Domain Metrics Check.
RAPIDAPI_KEY=
RAPIDAPI_REQUEST_TIMEOUT_MS=30000

# Internal operations snapshot. Set the same token in the Next.js app as OPS_AGENT_TOKEN.
OPS_AGENT_TOKEN=

# Next.js ops dashboard cloud collectors are configured in the frontend/Vercel
# environment, not in this ECS service env:
# SUPABASE_ACCESS_TOKEN, SUPABASE_PROJECT_REF, SUPABASE_DB_LIMIT_BYTES, SUPABASE_STORAGE_LIMIT_BYTES
# VERCEL_ACCESS_TOKEN, VERCEL_PROJECT_ID, VERCEL_TEAM_ID
# ALIYUN_ACCESS_KEY_ID, ALIYUN_ACCESS_KEY_SECRET, ALIYUN_REGION_ID,
# ALIYUN_ECS_INSTANCE_ID or ALIYUN_ECS_DISK_IDS, ALIYUN_RDS_INSTANCE_ID
# SUPABASE_PROJECT_REF=ehizdgntykwlrirqgzeh
# SUPABASE_DB_LIMIT_BYTES=524288000
# SUPABASE_STORAGE_LIMIT_BYTES=1073741824
# ALIYUN_REGION_ID=cn-hangzhou
# ALIYUN_ECS_INSTANCE_ID=i-bp1dt8qff1jbkjsezzm4
# ALIYUN_RDS_INSTANCE_ID=pgm-bp131hj5rnkdn39x
# VERCEL_PROJECT_NAME=altselfs
# VERCEL_PROJECT_ID=prj_YIy2as4BnAEqy3YrstW1rZPkrZb1
# VERCEL_TEAM_ID=team_F093LUiKgS5Dgbt0cwtikjA4
